{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "swearjar-route": {
        "ClusterId": "swearjar-cluster",
        "Match": { "Path": "/api/entries/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "default": { "Address": "https://localhost:7201" } }
      },
      "swearjar-cluster": {
        "Destinations": { "default": { "Address": "https://localhost:7202" } }
      }
    }
  }
}

